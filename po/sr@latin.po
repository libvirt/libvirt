#, c-format
msgid ""
"\n"
"%1$s [options]... [<command_string>]\n"
"%2$s [options]... <command> [args...]\n"
"\n"
"  options:\n"
"    -c | --connect=URI      daemon admin connection URI\n"
"    -d | --debug=NUM        debug level [0-4]\n"
"    -h | --help             this help\n"
"    -l | --log=FILE         output logging to file\n"
"    -q | --quiet            quiet mode\n"
"    -v                      short version\n"
"    -V                      long version\n"
"         --version[=TYPE]   version, TYPE is short or long (default short)\n"
"  commands (non interactive mode):\n"
"\n"
msgstr ""
"\n"
"%1$s [mogućnosti]... [<command_string>]\n"
"%2$s [mogućnosti]... <command> [argumenti...]\n"
"\n"
"  mogućnosti:\n"
"    -c | --connect=URI      URI veze administratora pozadinca\n"
"    -d | --debug=BROJ        nivo otklanjanja grešaka [0-4]\n"
"    -h | --help             ova pomoć\n"
"    -l | --log=DATOTEKA      izlaz beleženja u datoteku\n"
"    -q | --quiet            tihi režim\n"
"    -v                      kratko izdanje\n"
"    -V                      dugo izdanje\n"
"         --version[=VRSTA]   izdanje, VRSTA je kratko ili dugo (podrazumevano kratko)\n"
"  naredbe (neinteraktivni režim):\n"
"\n"

#, c-format
msgid ""
"\n"
"%1$s [options]... [<command_string>]\n"
"%2$s [options]... <command> [args...]\n"
"\n"
"  options:\n"
"    -c | --connect=URI      hypervisor connection URI\n"
"    -d | --debug=NUM        debug level [0-4]\n"
"    -e | --escape <char>    set escape sequence for console\n"
"    -h | --help             this help\n"
"    -k | --keepalive-interval=NUM\n"
"                            keepalive interval in seconds, 0 for disable\n"
"    -K | --keepalive-count=NUM\n"
"                            number of possible missed keepalive messages\n"
"    -l | --log=FILE         output logging to file\n"
"    -q | --quiet            quiet mode\n"
"    -r | --readonly         connect readonly\n"
"    -t | --timing           print timing information\n"
"         --no-pkttyagent    suppress registration of pkttyagent\n"
"    -v                      short version\n"
"    -V                      long version\n"
"         --version[=TYPE]   version, TYPE is short or long (default short)\n"
"  commands (non interactive mode):\n"
"\n"
msgstr ""
"\n"
"%1$s [mogućnosti]... [<command_string>]\n"
"%2$s [mogućnosti]... <command> [argumenti...]\n"
"\n"
"  mogućnosti:\n"
"    -c | --connect=URI      URI veze hipervizora\n"
"    -d | --debug=BROJ       nivo otklanjanja grešaka [0-4]\n"
"    -e | --escape <char>    postavi nizu prekida za konzolu\n"
"    -h | --help             ova pomoć\n"
"    -k | --keepalive-interval=BROJ\n"
"                            period održavanja veze u sekundama, 0 za onemogućavanje\n"
"    -K | --keepalive-count=BROJ\n"
"                            broj mogućih propuštenih poruka održavanja veze\n"
"    -l | --log=DATOTEKA     izlaz beleženja u datoteku\n"
"    -q | --quiet            tihi režim\n"
"    -r | --readonly         poveži se samo za čitanje\n"
"    -t | --timing           ispiši podatke o vremenu\n"
"         --no-pkttyagent    potisni registraciju „pkttyagent“-a\n"
"    -v                      kratko izdanje\n"
"    -V                      dugo izdanje\n"
"         --version[=VRSTA]  izdanje, VRSTA je kratko ili dugo (podrazumevano kratko)\n"
"  naredbe (neinteraktivni režim):\n"
"\n"

#, c-format
msgid ""
"\n"
"%1$s mode [options] [extra file] [< def.xml]\n"
"\n"
"  Modes:\n"
"    -a | --add                     load profile\n"
"    -c | --create                  create profile from template\n"
"    -D | --delete                  unload profile and delete generated rules\n"
"    -r | --replace                 reload profile\n"
"    -R | --remove                  unload profile\n"
"  Options:\n"
"    -d | --dryrun                  dry run\n"
"    -u | --uuid <uuid>             uuid (profile name)\n"
"    -h | --help                    this help\n"
"  Extra File:\n"
"    -f | --add-file <file>         add file to a profile generated from XML\n"
"    -F | --append-file <file>      append file to an existing profile\n"
"\n"
msgstr ""
"\n"
"%1$s režim [mogućnosti] [dodatna datoteka] [< def.xml]\n"
"\n"
"  Režimi:\n"
"    -a | --add                     učitaj profil\n"
"    -c | --create                  napravi profil iz šablona\n"
"    -D | --delete                  ukloni profil i obriši stvorena pravila\n"
"    -r | --replace                 ponovo učitaj profil\n"
"    -R | --remove                  ukloni profil\n"
"  Mogućnosti:\n"
"    -d | --dryrun                  probno pokretanje\n"
"    -u | --uuid <uuid>             uuid (naziv profila)\n"
"    -h | --help                    ova pomoć\n"
"  Dodatna datoteka:\n"
"    -f | --add-file <file>         dodaj datoteku u profil stvoren iz XML-a\n"
"    -F | --append-file <file>      prikači datoteku u postojeći profil\n"
"\n"

