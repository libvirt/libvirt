#, c-format
msgid "!!! SSH HOST KEY VERIFICATION FAILED !!!: Identity of host '%1$s:%2$d' differs from stored identity. Please verify the new host key '%3$s' to avoid possible man in the middle attack. The key is stored in '%4$s'."
msgstr "!!! ПРОВЕРА SSH КЉУЧА ДОМАЋИНА НИЈЕ УСПЕЛА !!!: Идентитет домаћина „%1$s:%2$d“ се разликује од сачуваног идентитета. Потврдите нови кључ домаћина „%3$s“ како бисте избегли могући напад „човек у средини“. Кључ је сачуван у „%4$s“."

#, c-format
msgid "$%1$s value should be between 0 and %2$d"
msgstr "Вредност $%1$s треба да буде између 0 и %2$d"

#, c-format
msgid "%1$s\n"
msgstr "%1$s\n"

#, c-format
msgid "%1$s %2$s"
msgstr "%1$s %2$s"

#, c-format
msgid "%1$s %2$s '%3$s' has an unsupported type '%4$s'"
msgstr "%1$s %2$s „%3$s“ има неподржану врсту „%4$s“"

#, c-format
msgid "%1$s %2$s '%3$s' has unsupported type '%4$s', expecting '%5$s' or '%6$s'"
msgstr "%1$s %2$s „%3$s“ има неподржану врсту „%4$s“, очекује се „%5$s“ или „%6$s“"

#, c-format
msgid "%1$s (on destination side) does not support the --migration option needed for migration with shared storage"
msgstr "%1$s (на одредишној страни) не подржава могућност --migration потребну за миграцију са дељеним складиштем"

#, c-format
msgid "%1$s (out of %2$d)"
msgstr "%1$s (од %2$d)"

#, c-format
msgid "%1$s can't be empty"
msgstr "%1$s не може бити празно"

#, c-format
msgid "%1$s cannot be set higher than %2$s"
msgstr "%1$s не може бити постављено више од %2$s"

#, c-format
msgid "%1$s cannot parse GID '%2$s'"
msgstr "%1$s не може да распозна ГИД „%2$s“"

#, c-format
msgid "%1$s cannot parse UID '%2$s'"
msgstr "%1$s не може да распозна УИД „%2$s“"

#, c-format
msgid "%1$s disk is not supported with this QEMU binary"
msgstr "%1$s диск није подржан са овим извршним бинарном датотеком Кемуа"

#, c-format
msgid "%1$s does not support file storage"
msgstr "%1$s не подржава складиште датотека"

#, c-format
msgid "%1$s does not support passing a passphrase using a file descriptor"
msgstr "%1$s не подржава прослеђивање лозинке коришћењем описника датотеке"

#, c-format
msgid "%1$s does not support passing passphrase via file descriptor"
msgstr "%1$s не подржава прослеђивање лозинке преко описника датотеке"

#, c-format
msgid "%1$s expects UID and GID parameters"
msgstr "%1$s очекује UID и GID параметре"

#, c-format
msgid "%1$s family specified for non-IPv4 address '%2$s' in network '%3$s'"
msgstr "%1$s породица је наведена за не-ИПв4 адресу „%2$s“ у мрежи „%3$s“"

